{
  "name": "@knowledge-atlas/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Knowledge Atlas.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@google/genai": "^2.7.0",
    "@huggingface/transformers": "^4.2.0",
    "@knowledge-atlas/shared": "file:../../packages/shared",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "pg": "^8.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.7"
  }
}
